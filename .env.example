# Genes Platform Configuration
# Copy this file to .env and customize values

# Database
POSTGRES_PASSWORD=genes_secure_password_change_this

# Security
SECRET_KEY=generate_a_secure_random_key_here

# Application
DEBUG=false
API_PORT=8000

# Docker
DOCKER_NETWORK=genes_network

# Agent Settings
MAX_AGENTS=50
AGENT_APPROVAL_REQUIRED=true
