        "agent_id": CONFIG["agent_id"],
        "name": CONFIG["name"],
        "purpose": CONFIG["purpose"],
        "status": "operational"
    }


@app.get("/health", response_model=HealthResponse)
async def health():
    """Health check"""
    return HealthResponse(
        status="healthy",
        agent_id=CONFIG["agent_id"],
        name=CONFIG["name"]
    )


